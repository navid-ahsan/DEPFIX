# Environment Configuration Template
# Copy this file to .env and fill in your values
# This file should NOT be committed to version control

# === RAG Application Settings ===
ENV=lab_model
MODEL=my_mistral:latest
PROJECT_ROOT=/home/navid/project/socialwork

# === Database Configuration ===
# PostgreSQL with PGVector
POSTGRES_USER=postgres
POSTGRES_PASSWORD=root
POSTGRES_DB=vector_db
DATABASE_HOST=pgvector
DATABASE_PORT=5432

# Connection string (auto-generated from above, can override)
# DATABASE_URL=postgresql+psycopg2://postgres:root@pgvector:5432/vector_db

# === Ollama Configuration ===
OLLAMA_HOST=http://ollama:11434
OLLAMA_KEEP_ALIVE=-1
OLLAMA_MODELS=/root/.ollama/models

# === RAG Collection Settings ===
COLLECTION_NAME=Error_handling
CHUNK_SIZE=1024
CHUNK_OVERLAP=300

# === Embedding Model Settings ===
# For lab_model environment
LAB_EMBEDDING_MODEL=nomic-embed-text

# For dgx_model environment
DGX_EMBEDDING_MODEL=nomic-embed-text

# === API Server Settings ===
API_HOST=0.0.0.0
API_PORT=8000
API_LOG_LEVEL=INFO

# === RAG Evaluation Settings ===
EVAL_DATASET_PATH=src/eval_dataset.json
RAGAS_EVALUATION_TIMEOUT=900
RAGAS_BATCH_SIZE=2

# === Logging Configuration ===
LOG_LEVEL=INFO
LOG_FORMAT=%(asctime)s - %(levelname)s - %(message)s
LOG_DIR=logs

# === Docker-specific ===
DOCKER_REGISTRY=
DOCKER_IMAGE_TAG=latest
CONTAINER_MEMORY_LIMIT=8G
CONTAINER_CPU_LIMIT=4

# === GPU Configuration (for dgx_model) ===
CUDA_VISIBLE_DEVICES=0
NVIDIA_VISIBLE_DEVICES=all

# === CI/CD Environment ===
CI_ENVIRONMENT=false
CI_COMMIT_SHA=
CI_BRANCH_NAME=main
